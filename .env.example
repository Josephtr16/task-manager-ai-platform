# Root environment template for Task Manager AI Platform
# Copy values into backend/.env and ai-service/.env as needed.

# =========================
# Backend (backend/.env)
# =========================
PORT=5000
MONGO_URI=mongodb://localhost:27017/taskmanager
JWT_SECRET=generate_a_strong_random_secret_here
JWT_EXPIRE=7d
NODE_ENV=development

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_rotated_smtp_username
SMTP_PASS=your_rotated_smtp_app_password
FROM_NAME="TaskFlow AI"
FROM_EMAIL="noreply@taskflow.ai"

APP_URL=http://localhost:3000
USE_MOCK_AI=true

# =========================
# AI Service (ai-service/.env)
# =========================
GROQ_API_KEY=your_rotated_groq_api_key
